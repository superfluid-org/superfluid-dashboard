# Dashboard origin for postMessage target (required)
NEXT_PUBLIC_DAPP_ORIGIN=http://localhost:3000

# Required — find these in your Turnkey dashboard (app.turnkey.com)
NEXT_PUBLIC_ORGANIZATION_ID=<your-turnkey-org-id>
NEXT_PUBLIC_AUTH_PROXY_CONFIG_ID=<your-auth-proxy-config-id>
# Session TTL: org-wide in Turnkey Dashboard → Wallet Kit → Authentication (https://app.turnkey.com/dashboard/v2/wallet-kit?tab=authentication). PoC org: 2592000 (30 days), not default 900.

# Optional — defaults shown
NEXT_PUBLIC_API_BASE_URL=https://api.turnkey.com
NEXT_PUBLIC_AUTH_PROXY_BASE_URL=https://authproxy.turnkey.com
